---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../utils/i18n';
import { WebsiteCard } from '../components/ui/WebsiteCard';
import { DeferredComments } from '../components/comments/DeferredComments';

const t = useTranslations('zh');
---

<Layout title={`${t('about.title')} - Mark's Backyard`}>
	<div class="mx-auto max-w-3xl px-4 py-12 md:py-20">
		<h1 class="mb-8 text-left text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100">
			{t('about.title')}
		</h1>

		<article class="prose prose-lg dark:prose-invert prose-slate max-w-none">
			<div class="space-y-8 text-slate-700 dark:text-slate-300">
				{/* Self Intro */}
				<p class="text-xl leading-relaxed font-medium text-slate-800 dark:text-slate-200">
					{t('about.intro')}
				</p>

				{/* About Website */}
				<section>
					<h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-slate-100">
						{t('about.originTitle')}
					</h2>
					<p class="mb-6 leading-relaxed">
						{/* 这里的 Trans 逻辑在 Astro 中可以通过插值处理 */}
						是在2026考研期间（也就是2025年），偶然看到了一些个人博客，比如 
						<a
							href="https://blog.zhilu.site/"
							target="_blank"
							rel="noopener noreferrer"
							class="text-blue-600 underline decoration-2 underline-offset-2 transition-colors hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
						>
							blog.zhilu.site
						</a>
						，精美又高效，文笔还很成熟，让我感到十分佩服☺️。
					</p>

					<WebsiteCard
						client:visible
						url="https://blog.zhilu.site/"
						title="纸鹿摸鱼处"
						description="纸鹿大佬的博客，精美又高效，文笔成熟，是本站的灵感来源之一。"
						variant="horizontal"
						className="not-prose mx-auto my-6 max-w-lg"
					/>
				</section>

				{/* Building Process */}
				<section>
					<h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-slate-100">
						{t('about.techTitle')}
					</h2>
					<p class="leading-relaxed">{t('about.techContent')}</p>

					<WebsiteCard
						client:visible
						url="https://github.com/MarkXuJQ/Mark-blog"
						title="我的网站源码"
						description="这里是我的网站的源码仓库，欢迎同学们前来发现问题、一起学习！"
						variant="horizontal"
						className="not-prose mx-auto my-6 max-w-lg"
					/>
				</section>

				{/* Future */}
				<p class="border-l-4 border-slate-200 pl-4 leading-relaxed text-slate-600 italic dark:border-slate-700 dark:text-slate-400">
					{t('about.futureContent')}
				</p>
			</div>
		</article>

		{/* Comments Section */}
		<div class="mt-16 border-t border-slate-200 pt-8 dark:border-slate-800">
			<DeferredComments client:visible />
		</div>
	</div>
</Layout>
